<div id="background">
	<div id="page">

		<div id="header">
			<div id="logo">
				<a href="/">
					<img
						src="/images/logo.png"
						alt="Travlr Getaways logo"
						height="100"
						width="200"
					>
				</a>
			</div>

			<div id="navigation">
				<ul>
					<li>
						<a href="/">Home</a>
					</li>

					<li class="selected">
						<a href="/travel">Travel</a>
					</li>

					<li>
						<a href="/rooms.html">Rooms</a>
					</li>

					<li>
						<a href="/meals.html">Meals</a>
					</li>

					<li>
						<a href="/news.html">News</a>
					</li>

					<li>
						<a href="/about.html">About</a>
					</li>

					<li>
						<a href="/contact.html">Contact</a>
					</li>
				</ul>
			</div>
		</div>

		<div id="contents">
			<div class="box">
				<div>
					<div class="body">
						<h1>{{title}}</h1>

						<ul id="sites">
							{{#each trips}}
								<li>
									<a href="/travel">
										<img
											src="/images/{{this.image}}"
											alt="{{this.name}}"
										>
									</a>

									<h2>
										<a href="/travel">{{this.name}}</a>
									</h2>

									<p>
										{{this.description}}
									</p>
								</li>
							{{/each}}
						</ul>
					</div>
				</div>
			</div>
		</div>

	</div>

	<div id="footer">
		<div>
			<ul class="navigation">
				<li>
					<a href="/">Home</a>
				</li>

				<li class="active">
					<a href="/travel">Travel</a>
				</li>

				<li>
					<a href="/rooms.html">Rooms</a>
				</li>

				<li>
					<a href="/meals.html">Meals</a>
				</li>

				<li>
					<a href="/news.html">News</a>
				</li>

				<li>
					<a href="/about.html">About</a>
				</li>

				<li>
					<a href="/contact.html">Contact</a>
				</li>
			</ul>

			<div id="connect">
				<a href="#" class="pinterest" aria-label="Pinterest"></a>
				<a href="#" class="facebook" aria-label="Facebook"></a>
				<a href="#" class="twitter" aria-label="Twitter"></a>
				<a href="#" class="googleplus" aria-label="Social media"></a>
			</div>
		</div>

		<p>
			© 2026 Travlr Getaways. Full-Stack Web Application by
			Tania Boursiquot.
		</p>
	</div>
</div>